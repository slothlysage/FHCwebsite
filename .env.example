# Copy to .env.local and fill in. Never commit the filled version.

# --- Database ---
DATABASE_URL=postgresql://user:pass@localhost:5432/fhc

# --- Stripe (TEST MODE ONLY during development) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Safety interlock: must be explicitly "true" to permit an sk_live_ key.
ALLOW_LIVE=false

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin bootstrap (used once by the seed script) ---
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=

# --- Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# --- Email ---
RESEND_API_KEY=
ORDER_NOTIFICATION_EMAIL=

# --- Monitoring (optional in dev) ---
SENTRY_DSN=
